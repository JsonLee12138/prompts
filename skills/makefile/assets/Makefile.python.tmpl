# Python Project Makefile
# Auto-generated help: `make` or `make help`

.DEFAULT_GOAL := help
SHELL := /bin/bash
APP_NAME := $(shell basename $(CURDIR))
PYTHON := $(shell command -v python3 || command -v python)
PIP := $(PYTHON) -m pip
VENV_DIR := .venv

.PHONY: help install dev test lint format type-check clean build publish docker-build docker-run

help: ## 显示帮助信息
	@grep -E '^[a-zA-Z_-]+:.*?## ' $(MAKEFILE_LIST) | sed 's/:.*##/:/' | awk -F: '{gsub(/^ /, "", $$2); printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

venv: ## 创建虚拟环境
	$(PYTHON) -m venv $(VENV_DIR)
	@echo "激活: source $(VENV_DIR)/bin/activate"

install: ## 安装依赖
	$(PIP) install -e ".[dev]"

install-prod: ## 仅安装生产依赖
	$(PIP) install -e .

dev: ## 启动开发服务器
	$(PYTHON) -m uvicorn $(APP_NAME).main:app --reload

test: ## 运行测试
	$(PYTHON) -m pytest -v

test-cover: ## 运行测试并显示覆盖率
	$(PYTHON) -m pytest --cov=$(APP_NAME) --cov-report=html --cov-report=term
	@echo "覆盖率报告: htmlcov/index.html"

lint: ## 运行 linter
	ruff check .
	mypy .

format: ## 格式化代码
	ruff format .
	ruff check --fix .

type-check: ## 运行类型检查
	mypy .

build: ## 构建分发包
	$(PYTHON) -m build

publish: ## 发布到 PyPI
	twine upload dist/*

clean: ## 清理构建产物
	rm -rf dist/ build/ *.egg-info/ .pytest_cache/ htmlcov/ coverage.xml .mypy_cache/

docker-build: ## 构建 Docker 镜像
	docker build -t $(APP_NAME):latest .

docker-run: ## 运行 Docker 容器
	docker run --rm -p 8000:8000 $(APP_NAME):latest
